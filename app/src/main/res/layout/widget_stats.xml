<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_widget_bg"
    android:padding="8dp">

    <!-- Title / Branding -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Activity"
        android:textColor="#B0BEC5"
        android:textSize="12sp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp" />

    <!-- Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Steps Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_widget_steps"
                android:tint="#4CAF50"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/widget_steps_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" steps"
                android:textSize="14sp"
                android:textColor="#B0BEC5"
                android:layout_gravity="bottom"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Calories Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_widget_fire"
                android:tint="#FF9800"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/widget_calories_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" kcal"
                android:textSize="12sp"
                android:textColor="#B0BEC5"
                android:layout_gravity="bottom"
                android:layout_marginBottom="3dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Tap to refresh hint (bottom) -->
    <TextView
        android:id="@+id/widget_last_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="Tap to refresh"
        android:textSize="10sp"
        android:textColor="#546E7A"
        android:layout_marginBottom="2dp"/>

</RelativeLayout>

